<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="NARI"
        android:letterSpacing="0.2"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Reverse Tethering VPN"
        android:textColor="@color/nari_text_secondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Pulsating effect background -->
    <View
        android:id="@+id/pulse_bg"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_btn_circle"
        android:backgroundTint="@color/nari_accent_glow"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="@+id/btn_toggle"
        app:layout_constraintEnd_toEndOf="@+id/btn_toggle"
        app:layout_constraintStart_toStartOf="@+id/btn_toggle"
        app:layout_constraintTop_toTopOf="@+id/btn_toggle" />

    <!-- Main Circular Toggle Button -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_toggle"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:cardBackgroundColor="@color/nari_card_bg"
        app:cardCornerRadius="80dp"
        app:cardElevation="16dp"
        app:strokeColor="@color/nari_card_stroke"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <ImageView
            android:id="@+id/iv_power_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_power"
            app:tint="@color/nari_text_secondary" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Tap to Connect"
        android:textColor="@color/nari_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_toggle" />

    <TextView
        android:id="@+id/tv_ip_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Relay: 127.0.0.1:4242"
        android:textColor="@color/nari_text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_status" />

</androidx.constraintlayout.widget.ConstraintLayout>
